Attribute VB_Name = "modImport"
Option Explicit

''' <summary>
''' ?×?J¥~???t°????????×
''' </summary>
Public Sub ImportLeaveData()
    Dim fd As Object
    Dim fileSelected As String
    
    ' 1. ?u¥X???×??????????
    fileSelected = Application.GetOpenFilename("Excel Files (*.xls; *.xlsx; *.xlsm), *.xls; *.xlsx; *.xlsm", , "???????t???t???×¥X????°???????")
    
    If fileSelected = "False" Then
        MsgBox "?w?????×?J??§@?C", vbInformation, "?£¥?"
        Exit Sub
    End If
    
    ' 2. ??‾??u???}?l
    On Error GoTo ErrorHandler
    Application.ScreenUpdating = False
    Application.Calculation = xlCalculationManual
    Application.EnableEvents = False
    
    Dim wbSource As Workbook
    Dim wsSource As Worksheet
    Dim wsDest As Worksheet
    
    ' 3. ?]?w¥????u§@?? (?b¥??????‾??)
    Set wsDest = ThisWorkbook.Sheets("?t°??????w")
    
    ' ?M°£¥????u§@?????????? (?O‾d???@?????Y)
    Dim lastRowDest As Long
    lastRowDest = wsDest.Cells(wsDest.Rows.Count, "A").End(xlUp).Row
    If lastRowDest > 1 Then
        wsDest.Range("A2:L" & lastRowDest).ClearContents
    End If
    
    ' 4. ?}±???·??????‾ (°???)
    Set wbSource = Workbooks.Open(Filename:=fileSelected, ReadOnly:=True)
    
    ' ??§b?G?M§??A·????u§@???]?q±`?O???@???A???W??§t?? "?t°?" ?? "Sheet"?^
    Dim sheetFound As Boolean
    Dim wsLoop As Worksheet
    sheetFound = False
    
    For Each wsLoop In wbSource.Worksheets
        If InStr(wsLoop.Name, "?t°?") > 0 Or InStr(wsLoop.Name, "Sheet") > 0 Then
            Set wsSource = wsLoop
            sheetFound = True
            Exit For
        End If
    Next wsLoop
    
    ' ?Y?S§???‾S?w?W???A?????@???u§@??
    If Not sheetFound Then
        Set wsSource = wbSource.Worksheets(1)
    End If
    
    ' 5. ±??y?P?×?J????
    Dim sourceLastRow As Long
    sourceLastRow = wsSource.Cells(wsSource.Rows.Count, "A").End(xlUp).Row
    
    ' §P?_???Y?????m
    Dim headerRow As Long
    Dim r As Long
    headerRow = 1 ' ?w?]?°?? 1 ??
    
    ' ±??y?e 10 ???M§?¥]§t "????" ?M "?m?W" ?????Y?C
    For r = 1 To MinValue(10, sourceLastRow)
        If InStr(wsSource.Cells(r, 1).Value, "????") > 0 And (InStr(wsSource.Cells(r, 3).Value, "?m?W") > 0 Or InStr(wsSource.Cells(r, 2).Value, "????") > 0) Then
            headerRow = r
            Exit For
        End If
    Next r
    
    Dim destRow As Long
    destRow = 2 ' ±q?? 2 ???}?l?g?J
    
    ' ±q???Y?C?U?@???}?l????
    Dim colCount As Integer
    colCount = 12 ' ?@?? 12 ??????
    
    Dim cellVal As String
    For r = (headerRow + 1) To sourceLastRow
        cellVal = Trim(CStr(wsSource.Cells(r, 1).Value))
        
        ' ±?°£???p·J?`?? (?}?Y?° ?? ??¥]§t '?@?p'/'??')
        If Left(cellVal, 1) = "??" Or InStr(cellVal, "??") > 0 Then
            ' ???L???p?C
            GoTo NextRow
        End If
        
        ' ±?°£???? (?p?G?????B?m?W?P???????°??)
        If cellVal = "" And Trim(CStr(wsSource.Cells(r, 3).Value)) = "" And Trim(CStr(wsSource.Cells(r, 5).Value)) = "" Then
            GoTo NextRow
        End If
        
        ' ???s???????? (1 ?? 12 ??)
        Dim c As Integer
        For c = 1 To colCount
            wsDest.Cells(destRow, c).Value = wsSource.Cells(r, c).Value
        Next c
        
        destRow = destRow + 1
        
NextRow:
    Next r
    
    ' 6. ??????·??????‾
    wbSource.Close SaveChanges:=False
    
    ' 7. ??‾??u????§??P???_
    Application.ScreenUpdating = True
    Application.Calculation = xlCalculationAutomatic
    Application.EnableEvents = True
    
    MsgBox "?t°??????×?J§????I?@?×?J " & (destRow - 2) & " ?§?????????C", vbInformation, "?×?J??¥\"
    Exit Sub

ErrorHandler:
    ' ?o¥????~???T?O???_ Excel ????
    On Error Resume Next
    If Not wbSource Is Nothing Then wbSource.Close SaveChanges:=False
    Application.ScreenUpdating = True
    Application.Calculation = xlCalculationAutomatic
    Application.EnableEvents = True
    MsgBox "?×?J??°????????o¥????~: " & Err.Description, vbCritical, "???~"
End Sub

Private Function MinValue(val1 As Long, val2 As Long) As Long
    If val1 < val2 Then
        MinValue = val1
    Else
        MinValue = val2
    End If
End Function
